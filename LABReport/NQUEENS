#include <stdio.h>
#include <stdlib.h>

int board[20], count = 0;

int place(int row, int col)
{
    int i;
    for (i = 1; i < row; i++)
    {
        if (board[i] == col || abs(board[i] - col) == abs(i - row))
            return 0;
    }
    return 1;
}

void queen(int row, int n)
{
    int col, i, j;

    for (col = 1; col <= n; col++)
    {
        if (place(row, col))
        {
            board[row] = col;

            if (row == n)
            {
                count++;
                printf("\nSolution %d:\n", count);

                for (i = 1; i <= n; i++)
                {
                    for (j = 1; j <= n; j++)
                    {
                        if (board[i] == j)
                            printf("Q ");
                        else
                            printf(". ");
                    }
                    printf("\n");
                }
            }
            else
            {
                queen(row + 1, n);
            }
        }
    }
}

int main()
{
    int n;

    printf("Enter number of queens: ");
    scanf("%d", &n);

    queen(1, n);

    printf("\nTotal solutions = %d\n", count);

    return 0;
}

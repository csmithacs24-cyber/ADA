#include <stdio.h>

void heap(int a[], int n, int p)
{
    int c, item;

    item = a[p];
    c = 2 * p + 1;

    while(c < n)
    {
        if(c + 1 < n && a[c] < a[c + 1])
            c++;

        if(item < a[c])
        {
            a[p] = a[c];
            p = c;
            c = 2 * p + 1;
        }
        else
        {
            break;
        }
    }

    a[p] = item;
}

void build_heap(int a[], int n)
{
    int i;

    for(i = (n / 2) - 1; i >= 0; i--)
    {
        heap(a, n, i);
    }
}

void heap_sort(int a[], int n)
{
    int i, temp;

    build_heap(a, n);

    for(i = n - 1; i > 0; i--)
    {
        temp = a[0];
        a[0] = a[i];
        a[i] = temp;

        heap(a, i, 0);
    }
}

int main()
{
    int a[20], n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");

    for(i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }

    heap_sort(a, n);

    printf("Sorted elements:\n");

    for(i = 0; i < n; i++)
    {
        printf("%d ", a[i]);
    }

    return 0;
}

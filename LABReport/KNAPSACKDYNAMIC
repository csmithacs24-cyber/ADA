#include <stdio.h>

int max(int a, int b)
{
    if(a > b)
        return a;
    else
        return b;
}

int main()
{
    int n, i, w;
    int wt[20], val[20];
    int W;
    int K[20][50];

    printf("Enter number of items: ");
    scanf("%d", &n);

    printf("Enter weights:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &wt[i]);

    printf("Enter values:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &val[i]);

    printf("Enter knapsack capacity: ");
    scanf("%d", &W);

    for(i = 0; i <= n; i++)
    {
        for(w = 0; w <= W; w++)
        {
            if(i == 0 || w == 0)
                K[i][w] = 0;

            else if(wt[i-1] <= w)
            {
                K[i][w] = max(val[i-1] + K[i-1][w - wt[i-1]],
                              K[i-1][w]);
            }
            else
            {
                K[i][w] = K[i-1][w];
            }
        }
    }

    printf("\nMaximum value = %d\n", K[n][W]);

    return 0;
}
